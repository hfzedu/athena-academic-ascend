// src/components/courses/CourseCard.tsx
import { Link } from 'react-router-dom';
import { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from '@/components/ui/card'; // Shadcn Card
import { Button } from '@/components/ui/button'; // Shadcn Button
import { Badge } from '@/components/ui/badge'; // Shadcn Badge
import { BookOpen, Users, CalendarDays } from 'lucide-react'; // Example Icons
import { type Course } from '@/services/courseService'; // Assuming your Course type

interface CourseCardProps {
  course: Course & { department?: { name: string }, sections_count?: number }; // Example enriched type
}

export function CourseCard({ course }: CourseCardProps) {
  return (
    <Card className="flex flex-col h-full card-hover"> {/* Your custom .card-hover */}
      <CardHeader>
        <div className="flex justify-between items-start">
          <CardTitle className="text-lg leading-tight">{course.name}</CardTitle>
          <Badge variant="outline" className="ml-2 whitespace-nowrap">{course.code}</Badge>
        </div>
        {course.department?.name && (
          <CardDescription className="text-xs">{course.department.name}</CardDescription>
        )}
      </CardHeader>
      <CardContent className="flex-grow space-y-2">
        <p className="text-sm text-muted-foreground line-clamp-3">
          {course.description || "No description available."}
        </p>
        <div className="flex flex-wrap gap-2 pt-2 text-xs">
          <Badge variant="secondary">
            <BookOpen className="w-3 h-3 mr-1.5" /> {course.credits} Credits
          </Badge>
          {course.sections_count !== undefined && (
             <Badge variant="secondary">
                <Users className="w-3 h-3 mr-1.5" /> {course.sections_count} Section(s)
             </Badge>
          )}
          {/* You could add term availability or other info here */}
        </div>
      </CardContent>
      <CardFooter>
        <Button asChild variant="default" size="sm" className="w-full">
          <Link to={`/courses/${course.id}`}>View Details</Link>
        </Button>
      </CardFooter>
    </Card>
  );
}
